---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const allTags = [...new Set(projects.flatMap((p) => p.data.tags))];
---

<Layout title="作品集">
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold mb-4">作品集</h1>
    <p class="text-lg text-gray-400 mb-8">過去開發的專案與作品。</p>

    <div class="flex flex-wrap gap-3 mb-12">
      <button class="tag-btn active px-4 py-2 text-sm rounded-full border border-blue-500 text-blue-400 transition-colors" data-tag="all">
        全部
      </button>
      {allTags.map((tag) => (
        <button class="tag-btn px-4 py-2 text-sm rounded-full border border-gray-700 text-gray-300 hover:border-blue-500 hover:text-blue-400 transition-colors" data-tag={tag}>
          {tag}
        </button>
      ))}
    </div>

    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <div
          data-tags={project.data.tags.join(",")}
        >
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            link={project.data.link}
            tags={project.data.tags}
            detailHref={`/Personal_Website/portfolio/${project.id}`}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll(".tag-btn");
  const grid = document.getElementById("project-grid");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => {
        b.classList.remove("active", "border-blue-500", "text-blue-400");
        b.classList.add("border-gray-700", "text-gray-300");
      });
      btn.classList.add("active", "border-blue-500", "text-blue-400");
      btn.classList.remove("border-gray-700", "text-gray-300");

      const tag = btn.dataset.tag;
      const cards = [...grid.children];

      cards.forEach((card) => {
        if (tag === "all") {
          card.style.display = "";
        } else {
          const cardTags = card.dataset.tags || "";
          card.style.display = cardTags.includes(tag) ? "" : "none";
        }
      });
    });
  });
</script>
