---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title}>
  <article class="max-w-3xl mx-auto px-6 py-20">
    <a
      href="/Personal_Website/portfolio"
      class="text-blue-400 hover:text-blue-300 transition-colors mb-8 inline-block"
    >
      ← 回作品集
    </a>

    <h1 class="text-4xl font-bold mb-4">{project.data.title}</h1>
    <p class="text-lg text-gray-400 mb-6">{project.data.description}</p>

    <div class="flex flex-wrap gap-2 mb-8">
      {project.data.tags.map((tag) => (
        <span class="px-3 py-1 text-sm bg-gray-800 text-gray-300 rounded-full">{tag}</span>
      ))}
    </div>

    {
      project.data.image && (
        <img src={project.data.image} alt={project.data.title} class="w-full rounded-xl mb-8" />
      )
    }

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>

    {
      project.data.link && (
        <a
          href={project.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-8 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          前往 GitHub →
        </a>
      )
    }
  </article>
</Layout>
