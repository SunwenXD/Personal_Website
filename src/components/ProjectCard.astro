---
export interface Props {
  title: string;
  description: string;
  image?: string;
  link?: string;
  tags?: string[];
  detailHref?: string;
}

const { title, description, image, link, tags = [], detailHref } = Astro.props;
---

<article class="relative bg-gray-900 border border-gray-800 rounded-xl overflow-hidden transition-transform duration-200 hover:scale-[1.02]">
  {
    detailHref && (
      <a href={detailHref} class="absolute inset-0 z-10" aria-label={title} />
    )
  }
  {
    image && (
      <img src={image} alt={title} class="w-full h-48 object-cover" />
    )
  }
  <div class="p-6">
    <h3 class="text-xl font-semibold mb-2">{title}</h3>
    <p class="text-gray-400 mb-4 leading-relaxed">{description}</p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-sm bg-gray-800 text-gray-300 rounded-full">{tag}</span>
          ))}
        </div>
      )
    }
    {
      link && (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-20 inline-block text-blue-400 hover:text-blue-300 transition-colors"
          onclick="event.stopPropagation()"
        >
          查看專案 →
        </a>
      )
    }
  </div>
</article>
